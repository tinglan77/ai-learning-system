<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ailearning.mapper.ChatHistoryMapper">

    <select id="findById" resultType="ChatHistory">
        SELECT * FROM chat_history WHERE id = #{id}
    </select>

    <select id="findByUserId" resultType="ChatHistory">
        SELECT * FROM chat_history WHERE user_id = #{userId} ORDER BY created_at ASC
    </select>

    <insert id="insert" parameterType="ChatHistory" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO chat_history (user_id, role, content)
        VALUES (#{userId}, #{role}, #{content})
    </insert>

    <delete id="deleteByUserId">
        DELETE FROM chat_history WHERE user_id = #{userId}
    </delete>

</mapper>
